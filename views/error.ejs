<!DOCTYPE html><html lang="<%= lang %>" data-theme="light"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Error · HKBU Forum</title><link rel="stylesheet" href="/style.css"></head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:var(--bg-secondary)">
<div class="empty"><div class="empty-icon">😕</div><h3><%= message %></h3><a href="/" class="btn btn-brand" style="margin-top:16px"><%= t('error.go_home') %></a></div>
<script>const s=localStorage.getItem('theme');if(s)document.documentElement.setAttribute('data-theme',s);</script>
</body></html>
