<%- include('partials/header', { title, pageTitle, activePage, sidebarBoards }) %>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px">
  <div style="font-size:18px;font-weight:700"><%= t('cal.title') %></div>
  <div style="display:flex;gap:6px;align-items:center">
    <a href="/calendar/export-all" class="btn btn-ghost btn-sm"><%= t('cal.export_ics') %></a>
  </div>
</div>

<div id="calendar-app">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px">
    <div style="display:flex;align-items:center;gap:8px">
      <button onclick="calNav(-1)" class="btn btn-ghost btn-sm">←</button>
      <span id="cal-title" style="font-size:15px;font-weight:700;min-width:160px;text-align:center"></span>
      <button onclick="calNav(1)" class="btn btn-ghost btn-sm">→</button>
      <button onclick="calToday()" class="btn btn-secondary btn-sm"><%= t('cal.today') %></button>
    </div>
    <div style="display:flex;gap:4px;background:var(--bg-modifier);padding:3px;border-radius:var(--r-sm)">
      <button class="btn btn-sm btn-brand cal-view-btn" data-view="month" onclick="setCalView('month')"><%= t('cal.month') %></button>
      <button class="btn btn-sm btn-ghost cal-view-btn" data-view="week" onclick="setCalView('week')"><%= t('cal.week') %></button>
      <button class="btn btn-sm btn-ghost cal-view-btn" data-view="list" onclick="setCalView('list')"><%= t('cal.list') %></button>
    </div>
  </div>
  <div id="cal-month" class="cal-grid"></div>
  <div id="cal-week" style="display:none"></div>
  <div id="cal-list" style="display:none"></div>
  <!-- Event detail modal -->
  <div id="cal-modal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:999;display:none;align-items:center;justify-content:center">
    <div id="cal-modal-content" style="background:var(--card-bg);border-radius:var(--r-lg);padding:24px;max-width:500px;width:90%;max-height:80vh;overflow:auto;box-shadow:0 8px 32px rgba(0,0,0,.2)"></div>
  </div>
</div>

<script>
var EVENTS = <%- events %>;
var LANG = '<%= lang %>';
var MONTHS = <%- JSON.stringify(t('cal.months')) %>;
var DAYS = ['<%= t("cal.sun") %>','<%= t("cal.mon") %>','<%= t("cal.tue") %>','<%= t("cal.wed") %>','<%= t("cal.thu") %>','<%= t("cal.fri") %>','<%= t("cal.sat") %>'];
var curDate = new Date(), curView = 'month';

function setCalView(v) {
  curView = v;
  document.querySelectorAll('.cal-view-btn').forEach(b => {
    b.className = 'btn btn-sm ' + (b.dataset.view === v ? 'btn-brand' : 'btn-ghost') + ' cal-view-btn';
  });
  document.getElementById('cal-month').style.display = v === 'month' ? '' : 'none';
  document.getElementById('cal-week').style.display = v === 'week' ? '' : 'none';
  document.getElementById('cal-list').style.display = v === 'list' ? '' : 'none';
  render();
}
function calNav(dir) { curDate.setMonth(curDate.getMonth() + (curView === 'week' ? 0 : dir)); if (curView === 'week') curDate.setDate(curDate.getDate() + dir * 7); render(); }
function calToday() { curDate = new Date(); render(); }

function eventsOnDate(dateStr) { return EVENTS.filter(e => e.event_date === dateStr); }
function fmtDate(d) { return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }

function showEvent(id) {
  var ev = EVENTS.find(e => e.id === id); if (!ev) return;
  var html = '<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px">'
    + '<h2 style="font-size:18px;font-weight:700">' + ev.title + '</h2>'
    + '<button onclick="closeModal()" style="background:none;border:none;font-size:20px;cursor:pointer;color:var(--text-muted)">×</button></div>'
    + '<div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px">'
    + '<div style="font-size:13px;color:var(--text-muted)">📅 ' + ev.event_date + (ev.event_time ? ' ' + ev.event_time : '') + '</div>'
    + (ev.location ? '<div style="font-size:13px;color:var(--text-muted)">📍 ' + ev.location + '</div>' : '')
    + '<div style="font-size:13px;color:var(--text-muted)">👤 ' + ev.username + '</div>'
    + '</div>'
    + (ev.description ? '<div style="font-size:14px;line-height:1.6;margin-bottom:16px;padding:12px;background:var(--bg-secondary);border-radius:var(--r-sm)">' + ev.description + '</div>' : '')
    + '<div style="display:flex;gap:8px">'
    + (ev.thread_id ? '<a href="/thread/' + ev.thread_id + '" class="btn btn-brand btn-sm"><%= t("cal.view_post") %></a>' : '')
    + '<a href="/calendar/export/' + ev.id + '" class="btn btn-ghost btn-sm"><%= t("cal.export_ics") %></a>'
    + '</div>';
  document.getElementById('cal-modal-content').innerHTML = html;
  document.getElementById('cal-modal').style.display = 'flex';
}
function closeModal() { document.getElementById('cal-modal').style.display = 'none'; }
document.getElementById('cal-modal').addEventListener('click', function(e) { if (e.target === this) closeModal(); });

function render() {
  var y = curDate.getFullYear(), m = curDate.getMonth();
  document.getElementById('cal-title').textContent = MONTHS[m] + ' ' + y;

  if (curView === 'month') renderMonth(y, m);
  else if (curView === 'week') renderWeek();
  else renderList();
}

function renderMonth(y, m) {
  var first = new Date(y, m, 1), startDay = first.getDay();
  var daysInMonth = new Date(y, m + 1, 0).getDate();
  var today = fmtDate(new Date());
  var html = '<div class="cal-header">' + DAYS.map(d => '<div class="cal-hd">' + d + '</div>').join('') + '</div><div class="cal-body">';
  for (var i = 0; i < startDay; i++) html += '<div class="cal-cell cal-empty"></div>';
  for (var d = 1; d <= daysInMonth; d++) {
    var ds = fmtDate(new Date(y, m, d));
    var evs = eventsOnDate(ds);
    var isToday = ds === today;
    html += '<div class="cal-cell' + (isToday ? ' cal-today' : '') + '">'
      + '<div class="cal-day">' + d + '</div>';
    evs.forEach(ev => {
      html += '<div class="cal-event" onclick="showEvent(' + ev.id + ')" title="' + ev.title + '">' + ev.title + '</div>';
    });
    html += '</div>';
  }
  html += '</div>';
  document.getElementById('cal-month').innerHTML = html;
}

function renderWeek() {
  var d = new Date(curDate);
  d.setDate(d.getDate() - d.getDay());
  var today = fmtDate(new Date());
  var html = '<div class="cal-week-grid">';
  for (var i = 0; i < 7; i++) {
    var ds = fmtDate(d);
    var evs = eventsOnDate(ds);
    var isToday = ds === today;
    html += '<div class="cal-week-day' + (isToday ? ' cal-today' : '') + '">'
      + '<div class="cal-week-hd"><span class="cal-week-dn">' + DAYS[i] + '</span><span class="cal-week-dd">' + d.getDate() + '</span></div>';
    evs.forEach(ev => {
      html += '<div class="cal-event" onclick="showEvent(' + ev.id + ')">' + (ev.event_time ? '<span style="font-weight:700">' + ev.event_time + '</span> ' : '') + ev.title + '</div>';
    });
    if (!evs.length) html += '<div style="font-size:11px;color:var(--text-light);padding:8px"><%= t("cal.no_events") %></div>';
    html += '</div>';
    d.setDate(d.getDate() + 1);
  }
  html += '</div>';
  document.getElementById('cal-week').innerHTML = html;
}

function renderList() {
  var upcoming = EVENTS.filter(e => e.event_date >= fmtDate(new Date())).sort((a,b) => a.event_date.localeCompare(b.event_date));
  var html = '<div style="font-size:14px;font-weight:700;margin-bottom:12px"><%= t("cal.upcoming") %></div>';
  if (!upcoming.length) html += '<div class="empty" style="padding:32px"><div class="empty-icon">📅</div><h3><%= t("cal.no_events") %></h3></div>';
  upcoming.forEach(ev => {
    html += '<div class="cal-list-item" onclick="showEvent(' + ev.id + ')">'
      + '<div class="cal-list-date"><div class="cal-list-dd">' + ev.event_date.split('-')[2] + '</div><div class="cal-list-mm">' + MONTHS[parseInt(ev.event_date.split('-')[1])-1] + '</div></div>'
      + '<div style="flex:1;min-width:0"><div style="font-weight:600;font-size:14px">' + ev.title + '</div>'
      + '<div style="font-size:12px;color:var(--text-muted);margin-top:2px">'
      + (ev.event_time ? '🕐 ' + ev.event_time + ' · ' : '') + (ev.location ? '📍 ' + ev.location : '') + '</div></div>'
      + '<span style="font-size:11px;color:var(--text-light)">' + ev.event_date + '</span></div>';
  });
  document.getElementById('cal-list').innerHTML = html;
}

render();
</script>

<%- include('partials/footer') %>
