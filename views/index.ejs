<%- include('partials/header', { title, pageTitle, activePage, sidebarBoards }) %>

<% if (!user) { %>
<div class="hero">
  <h1>🎓 <%= t('home.welcome') %></h1>
  <p><%= t('home.subtitle') %></p>
  <div style="display:flex;gap:10px;margin-bottom:20px">
    <a href="/register" class="btn btn-brand"><%= t('home.join_now') %></a>
    <a href="/login" class="btn btn-secondary" style="color:#fff;border-color:rgba(255,255,255,.3)"><%= t('home.login_btn') %></a>
  </div>
  <div class="hero-stats">
    <div class="hero-stat"><span><%= stats.users %></span><small><%= t('home.students') %></small></div>
    <div class="hero-stat"><span><%= stats.threads %></span><small><%= t('home.posts') %></small></div>
    <div class="hero-stat"><span><%= stats.replies %></span><small><%= t('home.replies') %></small></div>
  </div>
</div>
<% } else { %>
<div style="background:var(--brand-light);border:1px solid rgba(88,101,242,.2);border-radius:var(--r);padding:14px 18px;margin-bottom:20px;display:flex;align-items:center;gap:12px">
  <div class="avatar avatar-lg" style="background:<%= user.avatar_color %>"><%= user.username.charAt(0).toUpperCase() %></div>
  <div><div style="font-weight:600"><%= t('home.welcome_back') %><%= user.username %>! 👋</div><div style="font-size:12px;color:var(--text-muted)"><%= t('home.member_tag') %></div></div>
  <div style="margin-left:auto;display:flex;gap:8px">
    <div class="hero-stats" style="gap:16px">
      <div class="hero-stat" style="color:var(--text-normal)"><span style="font-size:16px;color:var(--brand)"><%= stats.threads %></span><small style="color:var(--text-muted)"><%= t('home.posts') %></small></div>
      <div class="hero-stat" style="color:var(--text-normal)"><span style="font-size:16px;color:var(--brand)"><%= stats.users %></span><small style="color:var(--text-muted)"><%= t('home.members') %></small></div>
    </div>
  </div>
</div>
<% } %>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
  <div style="font-size:13px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px"><%= t('home.all_boards') %></div>
</div>

<div class="boards-grid">
  <% boards.forEach(board => { %>
    <a href="/board/<%= board.id %>" class="board-row">
      <div class="board-row-icon"><%= board.icon %></div>
      <div class="board-row-info">
        <div class="board-row-name"><%= board.name %></div>
        <div class="board-row-desc"><%= board.description %></div>
        <% if (board.latest_title) { %>
          <div style="font-size:11px;color:var(--text-muted);margin-top:4px">
            <%= t('home.latest') %><span style="color:var(--brand)"><%= board.latest_title.length>36?board.latest_title.substring(0,36)+'…':board.latest_title %></span>
            <span style="color:var(--text-light)">· <%= board.latest_user %></span>
          </div>
        <% } %>
      </div>
      <div class="board-row-stats">
        <div class="board-row-count"><%= board.thread_count %></div>
        <div class="board-row-label"><%= t('board.posts') %></div>
        <div style="font-size:11px;color:var(--text-muted);margin-top:2px"><%= board.reply_count %> <%= t('board.replies') %></div>
      </div>
    </a>
  <% }) %>
</div>

<%- include('partials/footer') %>
