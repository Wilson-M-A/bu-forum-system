<%- include('partials/header', { title, pageTitle, sidebarBoards }) %>
<div class="breadcrumb"><a href="/"><%= t('thread.home') %></a><span class="sep">›</span><span><%= board.icon %> <%= board.name %></span></div>
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
  <div><div style="font-size:18px;font-weight:700"><%= board.icon %> <%= board.name %></div><div style="font-size:12px;color:var(--text-muted);margin-top:2px"><%= board.description %></div></div>
  <% if (user) { %><a href="/new-thread/<%= board.id %>" class="btn btn-brand"><%= t('board.new_post') %></a><% } else { %><a href="/login" class="btn btn-secondary"><%= t('board.login_post') %></a><% } %>
</div>
<div style="display:flex;gap:4px;margin-bottom:14px;background:var(--bg-modifier);padding:4px;border-radius:var(--r-sm);width:fit-content">
  <a href="?sort=latest" class="btn btn-sm <%= sort==='latest'?'btn-brand':'btn-ghost' %>" style="border:none"><%= t('board.latest') %></a>
  <a href="?sort=hot" class="btn btn-sm <%= sort==='hot'?'btn-brand':'btn-ghost' %>" style="border:none"><%= t('board.hot') %></a>
  <a href="?sort=unanswered" class="btn btn-sm <%= sort==='unanswered'?'btn-brand':'btn-ghost' %>" style="border:none"><%= t('board.unanswered') %></a>
</div>
<% if (threads.length === 0) { %>
  <div class="empty"><div class="empty-icon">📭</div><h3><%= t('board.no_posts') %></h3><p><%= t('board.be_first') %></p></div>
<% } else { %>
  <div class="thread-list">
    <% threads.forEach(ti => { %>
      <div class="thread-row <%= ti.is_pinned?'pinned':'' %>">
        <div class="avatar" style="background:<%= ti.avatar_color %>"><%= ti.username.charAt(0).toUpperCase() %></div>
        <div class="thread-main">
          <div class="thread-title-row">
            <% if (ti.is_pinned) { %><span class="badge badge-pin"><%= t('board.pinned') %></span><% } %>
            <% if (ti.is_locked) { %><span class="badge badge-lock"><%= t('board.locked') %></span><% } %>
            <a href="/thread/<%= ti.id %>" class="thread-title"><%= ti.title %></a>
          </div>
          <div class="thread-meta"><span><%= ti.username %></span><span>·</span><span data-time="<%= ti.created_at %>"><%= ti.created_at %></span><span>·</span><span><%= t('board.last_reply') %><span data-time="<%= ti.last_reply_at %>"><%= ti.last_reply_at %></span></span></div>
        </div>
        <div class="thread-stats">
          <div class="stat-item"><span class="stat-num"><%= ti.reply_count %></span><span class="stat-lbl"><%= t('board.replies') %></span></div>
          <div class="stat-item"><span class="stat-num"><%= ti.views %></span><span class="stat-lbl"><%= t('board.views') %></span></div>
          <div class="stat-item"><span class="stat-num"><%= ti.like_count %></span><span class="stat-lbl"><%= t('board.likes') %></span></div>
        </div>
      </div>
    <% }) %>
  </div>
  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (page>1) { %><a href="?sort=<%= sort %>&page=<%= page-1 %>"><%= t('board.prev') %></a><% } %>
      <% for (let p=1;p<=totalPages;p++) { %><% if(p===page){%><span class="current"><%= p %></span><%}else{%><a href="?sort=<%= sort %>&page=<%= p %>"><%= p %></a><%}%><% } %>
      <% if (page<totalPages) { %><a href="?sort=<%= sort %>&page=<%= page+1 %>"><%= t('board.next') %></a><% } %>
    </div>
  <% } %>
<% } %>
<%- include('partials/footer') %>
